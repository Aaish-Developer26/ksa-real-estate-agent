# ── LLM Configuration ─────────────────────────────────────────
# Option A: Groq — Recommended (free, no credit card)
# Sign up: console.groq.com
GROQ_API_KEY=

# Active model — change this one line to switch providers
LITELLM_MODEL=groq/llama-3.1-70b-versatile

# Option B: Google Gemini (1M tokens/day free)
# Sign up: aistudio.google.com
# GOOGLE_API_KEY=
# LITELLM_MODEL=gemini/gemini-1.5-flash

# Option C: Ollama local (zero cost, zero internet)
# LITELLM_MODEL=ollama/llama3.1

# ── Observability ─────────────────────────────────────────────
# Sign up: smith.langchain.com (free dev tier)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=riyadh-re-agent
LANGCHAIN_TRACING_V2=true

# ── Search Tool ───────────────────────────────────────────────
# Sign up: brave.com/search/api (2K queries/month free)
BRAVE_SEARCH_API_KEY=

# ── Database ──────────────────────────────────────────────────
# Uses Docker service name 'db' — NOT localhost
POSTGRES_URL=postgresql://agent_user:agent_pass@db:5432/riyadh_re
POSTGRES_USER=agent_user
POSTGRES_PASSWORD=agent_pass
POSTGRES_DB=riyadh_re

# ── Cache & Queue ─────────────────────────────────────────────
# Uses Docker service name 'redis' — NOT localhost
REDIS_URL=redis://redis:6379/0

# ── Application ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG
